/* PIN */
#pin-modal{position:fixed;inset:0;background:#1A1A1A;z-index:9999;
  display:flex;flex-direction:column;align-items:center;
  justify-content:center;padding:24px;}
.logo-pin{width:72px;height:72px;border-radius:50%;background:#F5C000;
  display:flex;align-items:center;justify-content:center;
  font-size:28px;font-weight:900;color:#1A1A1A;margin-bottom:20px;}
#pin-modal h2{color:#F5C000;font-size:20px;font-weight:700;
  margin-bottom:6px;text-align:center;}
#pin-modal p{color:#888;font-size:12px;margin-bottom:24px;text-align:center;}
#pin-input{background:#2D2D2D;border:2px solid #333;border-radius:12px;
  padding:16px 20px;font-size:28px;font-weight:700;color:#F5C000;
  text-align:center;width:200px;letter-spacing:8px;outline:none;
  -webkit-text-security:disc;}
#pin-input:focus{border-color:#F5C000;}
#pin-err{color:#E87722;font-size:12px;margin-top:10px;min-height:20px;text-align:center;}
#pin-btn{background:#F5C000;color:#1A1A1A;border:none;border-radius:12px;
  padding:14px 40px;font-size:15px;font-weight:700;cursor:pointer;margin-top:16px;}
.pin-dots{display:flex;gap:10px;margin-top:16px;}
.pin-dot{width:14px;height:14px;border-radius:50%;background:#333;transition:background .2s;}
.pin-dot.filled{background:#F5C000;}

/* HEADER */
.hd{background:#1A1A1A;}
.hd-top{padding:10px 14px;display:flex;align-items:center;gap:10px;}
.logo{width:40px;height:40px;border-radius:50%;background:#F5C000;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;font-weight:900;color:#1A1A1A;flex-shrink:0;}
.hd-txt h1{font-size:15px;font-weight:700;color:#F5C000;}
.hd-txt p{font-size:10px;color:rgba(255,255,255,.6);margin-top:2px;}
.hd-bar{height:4px;background:linear-gradient(90deg,#F5C000,#E87722);}

/* TABS */
.tabs{display:flex;background:#fff;border-radius:12px;padding:4px;
  margin:12px 12px 0;border:1px solid #ddd;}
.tab-btn{flex:1;padding:9px 4px;border:none;border-radius:8px;
  background:transparent;cursor:pointer;font-size:11px;font-weight:500;color:#888;}
.tab-btn.on{background:#1A1A1A;color:#F5C000;font-weight:700;}

.content{padding:12px;}
.panel{display:none;}.panel.on{display:block;}

/* CARDS */
.card{background:#fff;border-radius:12px;padding:14px;
  margin-bottom:12px;border:1px solid #ddd;}
.lbl{font-size:10px;font-weight:700;color:#888;text-transform:uppercase;
  letter-spacing:.06em;margin-bottom:10px;display:block;}
.field{margin-bottom:10px;}
.field label{font-size:11px;color:#888;display:block;margin-bottom:4px;font-weight:500;}
.field input,.field select,.field textarea{
  width:100%;border:1px solid #ddd;border-radius:9px;
  padding:11px 12px;font-size:15px;outline:none;
  background:#fff;-webkit-appearance:none;color:#1A1A1A;}
.field input:focus,.field select:focus{border-color:#F5C000;box-shadow:0 0 0 3px #FFF8DC;}
.field textarea{resize:vertical;min-height:80px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}

/* KPI */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;}
.kpi{background:#fff;border-radius:10px;padding:10px;text-align:center;border:1px solid #ddd;}
.kpi-v{font-size:22px;font-weight:700;}
.kpi-l{font-size:9px;color:#888;margin-top:2px;text-transform:uppercase;}

/* BOTÕES DE SELEÇÃO */
