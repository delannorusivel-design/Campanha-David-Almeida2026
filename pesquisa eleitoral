<script>
// ── PIN ───────────────────────────────────────────────
var PIN_HASH = "7a3ed03b12b784c2581ae5308e31f2a80248b481d8b0d369ee2193dcc3c1c4c5";
var SESSAO_KEY = "pesq_sessao_avante70";

async function hashPin(pin) {
  var enc = new TextEncoder().encode(pin);
  var buf = await crypto.subtle.digest("SHA-256", enc);
  return Array.from(new Uint8Array(buf))
    .map(function(b){return b.toString(16).padStart(2,"0");}).join("");
}

function verificarSessao() {
  try {
    var s = JSON.parse(sessionStorage.getItem(SESSAO_KEY)||"null");
    if (!s) return false;
    if (Date.now() - s.ts > 8*3600*1000) { sessionStorage.removeItem(SESSAO_KEY); return false; }
    return s.ok === true;
  } catch(e) { return false; }
}

async function verificarPin() {
  var pin = document.getElementById("pin-input").value.trim();
  if (pin.length < 4) { document.getElementById("pin-err").textContent="Digite 4 dígitos."; return; }
  var hash = await hashPin(pin);
  if (hash === PIN_HASH) {
    sessionStorage.setItem(SESSAO_KEY, JSON.stringify({ok:true,ts:Date.now()}));
    document.getElementById("pin-modal").style.display = "none";
    document.body.style.overflow = "";
    renderDash();
  } else {
    document.getElementById("pin-err").textContent = "PIN incorreto.";
    document.getElementById("pin-input").value = "";
    atualizarDots();
    document.getElementById("pin-btn").disabled = true;
    setTimeout(function(){document.getElementById("pin-btn").disabled=false;},2000);
  }
}

function atualizarDots() {
  var v = document.getElementById("pin-input").value;
  for(var i=0;i<4;i++) {
    var d=document.getElementById("pd"+i);
    if(d) d.className="pin-dot"+(i<v.length?" filled":"");
  }
}

// ── DADOS ─────────────────────────────────────────────
var CANDS = {
  aryel:  {nome:"Aryel Almeida",  num:"7070",  cor:"#E87722", key:"el_aryel"},
  daniel: {nome:"Daniel Almeida", num:"70070", cor:"#C49A00", key:"el_daniel"},
  david:  {nome:"David Almeida",  num:"70",    cor:"#A04000", key:"el_david"},
};

var WEBHOOK = "https://script.google.com/macros/s/AKfycbwo8lkCo7SY3g-Mu0pTkIIgEEBMcdyBn1n41GwWVHSbpCW2ZDSY6a_6DKO6d8p3mRE-/exec";
var TOKEN   = "avante70-am-2026-token-secreto";

var respostas  = JSON.parse(localStorage.getItem("pesq_respostas")||"[]");
var candAtivo  = "todos";

function escHtml(s) {
  if(!s) return "";
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#x27;");
}

function carregarBase() {
  var lista = [];
  Object.values(CANDS).forEach(function(c) {
    var l = JSON.parse(localStorage.getItem(c.key)||"[]");
    l.forEach(function(e){ e._cand=c; });
    lista = lista.concat(l);
  });
  return lista;
}

function filtrarBase() {
  var base = carregarBase();
  if (candAtivo !== "todos")
    base = base.filter(function(e){ return e._cand && e._cand.key === CANDS[candAtivo]?.key; });
  return base;
}

// ── TABS ──────────────────────────────────────────────
function setTab(id) {
  ["dash","disparo","config"].forEach(function(t){
    document.getElementById("panel-"+t).className = "panel"+(t===id?" on":"");
    document.getElementById("tab-"+t).className   = "tab-btn"+(t===id?" on":"");
  });
  if(id==="dash")    renderDash();
  if(id==="disparo") atualizarPreview();
}
function setNavTab(id) {
  setTab(id);
  ["dash","disparo","config"].forEach(function(t){
    document.getElementById("nav-"+t).className = "nav-btn"+(t===id?" on":"");
  });
}

// ── DASHBOARD ─────────────────────────────────────────
function renderDash() {
  var base = filtrarBase();
  var total = base.length;

  // KPIs
  var sim    = base.filter(function(e){return e.intencao==="SIM";}).length;
  var talvez = base.filter(function(e){return e.intencao==="TALVEZ";}).length;
  var nao    = base.filter(function(e){return e.intencao==="NAO";}).length;
  var resps  = respostas.filter(function(r){
    return candAtivo==="todos"||r.candidato===candAtivo;
  }).length;

  document.getElementById("kpi-row").innerHTML = [
    {v:total,  l:"Base total",  c:"#1A1A1A"},
    {v:sim,    l:"✅ SIM",      c:"#1A7A4A"},
    {v:talvez, l:"🤔 Indecisos",c:"#856404"},
    {v:resps,  l:"📊 Responderam",c:"#1B4F8A"},
  ].map(function(k){
    return '<div class="kpi"><div class="kpi-v" style="color:'+k.c+'">'+k.v+'</div>'+
      '<div class="kpi-l">'+k.l+'</div></div>';
  }).join("");

  // Tabs candidatos
  var tabs = [{slug:"todos",nome:"Todos",cor:"#1A1A1A"}].concat(
    Object.entries(CANDS).map(function(e){
      return {slug:e[0],nome:e[1].nome.split(" ")[0]+" "+e[1].num,cor:e[1].cor};
    })
  );
  document.getElementById("cand-tabs").innerHTML = tabs.map(function(t){
    var at = candAtivo===t.slug;
    return '<button class="cand-tab'+(at?" on":"") + '"'+
      (at?' style="background:'+t.cor+';border-color:'+t.cor+'"':'')+
      ' onclick="filtrarCand(\''+t.slug+'\')">'+ t.nome +'</button>';
  }).join("");

  // Gráfico intenção
  var intencoes = [
    {k:"SIM",     l:"✅ Vai votar",   cor:"#1A7A4A"},
    {k:"TALVEZ",  l:"🤔 Indeciso",    cor:"#F5C000"},
    {k:"NAO",     l:"❌ Contrário",   cor:"#E87722"},
    {k:"NAO_SABE",l:"❓ Não sabe",    cor:"#888"},
    {k:"",        l:"📭 Não informou",cor:"#ddd"},
  ];
  var maxInt = Math.max(sim, talvez, nao, 1);
  document.getElementById("grafico-intencao").innerHTML = intencoes.map(function(it){
    var n = base.filter(function(e){return (e.intencao||"")=== it.k;}).length;
    var pct = total>0?Math.round(n/total*100):0;
    var w   = total>0?Math.round(n/maxInt*100):0;
    return '<div class="bar-wrap">'+
      '<div class="bar-label">'+
        '<span>'+escHtml(it.l)+'</span>'+
        '<span style="color:'+it.cor+';font-weight:700">'+n+' ('+pct+'%)</span>'+
      '</div>'+
      '<div class="bar-track">'+
        '<div class="bar-fill" style="width:'+w+'%;background:'+it.cor+'">'+
          (w>12?pct+'%':'')+'</div>'+
      '</div>'+
    '</div>';
  }).join("");

  // Nuvem de temas
  var temas = {};
  base.forEach(function(e){
    if(e.interesse){temas[e.interesse]=(temas[e.interesse]||0)+1;}
  });
  var maxTema = Math.max.apply(null, Object.values(temas).concat([1]));
  var cores = ["#E87722","#F5C000","#1A7A4A","#1B4F8A","#4A235A","#7B241C","#856404"];
  document.getElementById("tema-cloud").innerHTML = Object.entries(temas)
    .sort(function(a,b){return b[1]-a[1];})
    .map(function(t,i){
      var tam = 10 + Math.round(t[1]/maxTema*8);
      var cor = cores[i%cores.length];
      return '<span class="tema-tag" style="background:'+cor+'22;color:'+cor+
        ';font-size:'+tam+'px">'+escHtml(t[0])+' ('+t[1]+')</span>';
    }).join("");

  // Gráfico por zona
  var zonas = ["Zona Norte","Zona Sul","Centro","Zona Oeste","Zona Leste","Interior"];
  document.getElementById("grafico-zonas").innerHTML = zonas.map(function(z){
    var zBase = base.filter(function(e){return e.zona===z;});
    var zSim  = zBase.filter(function(e){return e.intencao==="SIM";}).length;
    var pct   = zBase.length>0?Math.round(zSim/zBase.length*100):0;
    var cor   = pct>=60?"#1A7A4A":pct>=35?"#F5C000":"#E87722";
    return '<div class="bar-wrap">'+
      '<div class="bar-label">'+
        '<span>'+z+'</span>'+
        '<span style="color:'+cor+';font-weight:700">'+pct+'% fav · '+zBase.length+' eleit.</span>'+
      '</div>'+
      '<div class="bar-track">'+
        '<div class="bar-fill" style="width:'+pct+'%;background:'+cor+'">'+
          (pct>12?pct+'%':'')+'</div>'+
      '</div>'+
    '</div>';
  }).join("");

  renderRespostas();
}

function filtrarCand(slug) { candAtivo=slug; renderDash(); }

// ── RESPOSTAS ─────────────────────────────────────────
function renderRespostas() {
  var q = (document.getElementById("search-resp")||{}).value||"";
  q = q.toLowerCase();
  var lista = respostas.filter(function(r){
    var matchCand = candAtivo==="todos"||r.candidato===candAtivo;
    var matchQ = !q||r.nome.toLowerCase().includes(q)||r.fone.includes(q);
    return matchCand && matchQ;
  }).reverse();

  document.getElementById("lbl-respostas").textContent =
    "Respostas recebidas (" + lista.length + ")";

  var RESP_LABELS = {
    "1":{l:"✅ Vai votar",cls:"tag-sim"},
    "2":{l:"🤔 Indeciso",cls:"tag-talvez"},
    "3":{l:"❓ Com dúvidas",cls:"tag-ns"},
    "4":{l:"🔇 Não responde",cls:"tag-ns"},
  };

  if (!lista.length) {
    document.getElementById("lista-respostas").innerHTML =
      '<div style="text-align:center;padding:24px;color:#888;font-size:13px">'+
      'Nenhuma resposta registrada ainda.<br/>Dispare a pesquisa na aba 📤 Disparar.</div>';
    return;
  }

  document.getElementById("lista-respostas").innerHTML = lista.map(function(r){
    var rl = RESP_LABELS[r.resposta]||{l:r.resposta,cls:"tag-ns"};
    return '<div class="resp-card">'+
      '<div class="resp-nome">👤 '+escHtml(r.nome)+'</div>'+
      '<div class="resp-info">📱 '+escHtml(r.fone)+' · ⏰ '+r.hora+'</div>'+
      '<span class="resp-tag '+rl.cls+'">'+rl.l+'</span>'+
      (r.tema?'<span class="resp-tag tag-tema" style="margin-left:4px">'+escHtml(r.tema)+'</span>':'')+
      (r.obs?'<div style="font-size:10px;color:#888;margin-top:4px">'+escHtml(r.obs)+'</div>':'')+
    '</div>';
  }).join("");
}

// ── DISPARO ───────────────────────────────────────────
function getBaseDisparo() {
  var base = carregarBase();
  var cand    = document.getElementById("d-cand")?.value||"todos";
  var int     = document.getElementById("d-interesse")?.value||"";
  var zona    = document.getElementById("d-zona")?.value||"";
  var intencao= document.getElementById("d-intencao")?.value||"";

  if (cand !== "todos")
    base = base.filter(function(e){return e._cand&&e._cand.key===CANDS[cand]?.key;});
  if (int)
    base = base.filter(function(e){return e.interesse===int;});
  if (zona)
    base = base.filter(function(e){return e.zona===zona;});
  if (intencao)
    base = base.filter(function(e){return e.intencao===intencao;});

  // Remove opt-outs
  var optOuts = JSON.parse(localStorage.getItem("pesq_optouts")||"[]");
  base = base.filter(function(e){
    return !optOuts.includes((e.fone||"").replace(/\D/g,""));
  });

  return base;
}

function getMsgPadrao() {
  // Usa template salvo ou padrão neutro
  var p1 = localStorage.getItem("pesq_p1");
  if (p1) return p1;
  return "Olá, [NOME]! 👋\n\n" +
    "Instituto de Pesquisa Amazonas 2026.\n\n" +
    "Estamos realizando uma pesquisa eleitoral rápida!\n\n" +
    "Responda apenas com o número:\n\n" +
    "1️⃣ — Já sei em quem vou votar para Governador\n" +
    "2️⃣ — Ainda estou decidindo\n" +
    "3️⃣ — Não sei ainda\n" +
    "4️⃣ — Prefiro não responder\n\n" +
    "Obrigado pela participação! 🙏";
}

function atualizarPreview() {
  var base = getBaseDisparo();
  var candSlug = document.getElementById("d-cand")?.value||"todos";
  // cand não usado — pesquisa neutra
  var custom = (document.getElementById("d-pergunta-custom")?.value||"").trim();
  var msg  = custom || getMsgPadrao();
  var prev = msg.replace("[NOME]","Maria");

  if (document.getElementById("d-count"))
    document.getElementById("d-count").textContent = base.length;
  if (document.getElementById("preview-msg"))
    document.getElementById("preview-msg").textContent = prev;
}

function dispararPesquisa() {
  var base = getBaseDisparo();
  if (!base.length) {
    showFb("fb-disp","err","Nenhum eleitor encontrado com os filtros selecionados.");return;
  }

  var conf = confirm(
    "Confirmar disparo?\n\n" +
    base.length + " eleitores receberão a pesquisa via WhatsApp.\n\n" +
    "Esta ação é irreversível."
  );
  if (!conf) return;

  var candSlug = document.getElementById("d-cand").value;
  var custom   = document.getElementById("d-pergunta-custom").value.trim();

  var enviados = 0;
  base.forEach(function(e) {
    var msg = custom || getMsgPadrao();
    msg = msg.replace(/\[NOME\]/g, (e.nome||"").split(" ")[0]);

    enviados++;
  });

  // Salva log local
  var logs = JSON.parse(localStorage.getItem("pesq_disparos")||"[]");
  logs.push({
    dia:new Date().toISOString().slice(0,10),
    hora:new Date().toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"}),
    total:enviados, candidato:candSlug,
  });
  localStorage.setItem("pesq_disparos", JSON.stringify(logs));

  showFb("fb-disp","ok",
    "✅ "+enviados+" disparos registrados! Envie via Z-API pelo Apps Script.");
}

// ── IMPORTAR MANUAL ───────────────────────────────────
function importarManual() {
  var fone = document.getElementById("m-fone").value.trim();
  var resp = document.getElementById("m-resp").value;
  var obs  = document.getElementById("m-obs").value.trim();
  if (!fone||!resp) { alert("Preencha WhatsApp e resposta."); return; }

  // Busca eleitor na base
  var base = carregarBase();
  var el   = base.find(function(e){
    return (e.fone||"").replace(/\D/g,"")=== fone.replace(/\D/g,"");
  });

  var reg = {
    id:        Date.now(),
    fone:      fone,
    nome:      el?el.nome:"Não identificado",
    candidato: el&&el._cand?el._cand.key:"desconhecido",
    resposta:  resp,
    obs:       obs,
    dia:       new Date().toISOString().slice(0,10),
    hora:      new Date().toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"}),
    manual:    true,
  };

  respostas.push(reg);
  localStorage.setItem("pesq_respostas", JSON.stringify(respostas));

  document.getElementById("m-fone").value="";
  document.getElementById("m-resp").value="";
  document.getElementById("m-obs").value="";
  alert("✅ Resposta de "+(el?el.nome:fone)+" registrada!");
  renderDash();
}

function salvarConfig() {
  localStorage.setItem("pesq_p1", document.getElementById("cfg-p1").value);
  localStorage.setItem("pesq_p2", document.getElementById("cfg-p2").value);
  localStorage.setItem("pesq_p3", document.getElementById("cfg-p3").value);
  alert("✅ Configurações salvas!");
}

function fmtFone(inp) {
  var v=inp.value.replace(/\D/g,"");
  if(v.length>11)v=v.slice(0,11);
  if(v.length>6)      v="("+v.slice(0,2)+") "+v.slice(2,7)+"-"+v.slice(7);
  else if(v.length>2) v="("+v.slice(0,2)+") "+v.slice(2);
  inp.value=v;
}

function showFb(id,t,m) {
  var el=document.getElementById(id);
  if(!el)return;
  el.className="fb "+t; el.textContent=m;
  if(t==="ok"||t==="info") setTimeout(function(){el.className="fb";},5000);
  el.scrollIntoView({behavior:"smooth",block:"center"});
}

// ── INIT ──────────────────────────────────────────────
if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", function() {
    if (!verificarSessao()) {
      document.getElementById("pin-modal").style.display="flex";
      document.body.style.overflow="hidden";
    } else {
      document.getElementById("pin-modal").style.display="none";
      renderDash();
    }
  });
} else {
  if (!verificarSessao()) {
    document.getElementById("pin-modal").style.display="flex";
    document.body.style.overflow="hidden";
  } else {
    document.getElementById("pin-modal").style.display="none";
    renderDash();
  }
}
</script>
